{
  "schemaVersion": 3,
  "id": "gate-demo",
  "version": "1.0.0",
  "title": "v10 Hard Gate 演示蓝图",
  "description": "loop body 内 review 软打回 + gate_coverage 硬判定 — 都折返 dev (节点自含 skill)",
  "startNode": "requirements",
  "nodes": [
    {
      "id": "requirements",
      "title": "需求分析",
      "x": 226,
      "y": 74
    },
    {
      "id": "design",
      "title": "设计",
      "x": 227,
      "y": 213
    },
    {
      "id": "decompose",
      "title": "需求拆解",
      "x": 216,
      "y": 322
    },
    {
      "id": "iter",
      "kind": "loop",
      "title": "迭代开发 + 双层门禁",
      "x": 467,
      "y": 270,
      "iterator": {
        "kind": "tasks",
        "tasksSchemaRef": "default",
        "selectStrategy": "first-pending"
      },
      "body": {
        "startNode": "dev",
        "nodes": [
          {
            "id": "dev",
            "title": "实现一个任务",
            "x": 47,
            "y": 71
          },
          {
            "id": "review",
            "title": "Review (软打回)",
            "x": 220,
            "y": 71,
            "onFail": {
              "rewindTo": "dev",
              "ticketTitle": "Review 打回",
              "maxAttempts": 3
            }
          },
          {
            "id": "gate_coverage",
            "kind": "script",
            "title": "覆盖率门禁 (硬判定)",
            "description": "spawn check_coverage.js 验证任务产出文件存在并粗估覆盖率",
            "x": 400,
            "y": 71,
            "script": {
              "path": "scripts/check_coverage.js",
              "timeoutMs": 30000,
              "env": {
                "MIN_COVERAGE": "80"
              }
            },
            "onFail": {
              "rewindTo": "dev",
              "ticketTitle": "覆盖率不足",
              "maxAttempts": 3
            }
          }
        ],
        "edges": [
          {
            "from": "dev",
            "to": "review",
            "when": "status == \"ok\""
          },
          {
            "from": "review",
            "to": "gate_coverage",
            "when": "status == \"ok\""
          }
        ]
      },
      "maxIterations": 5
    }
  ],
  "edges": [
    {
      "from": "requirements",
      "to": "design",
      "when": "status == \"ok\""
    },
    {
      "from": "design",
      "to": "decompose",
      "when": "status == \"ok\""
    },
    {
      "from": "decompose",
      "to": "iter",
      "when": "status == \"ok\""
    }
  ],
  "tasksSchemas": {
    "default": {
      "requiredFields": {
        "id": {
          "type": [
            "string",
            "number"
          ]
        },
        "status": {
          "type": "string",
          "default": "pending"
        }
      },
      "recommendedFields": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "output": {
          "type": "string"
        }
      },
      "userFields": {},
      "extensionFieldsAllowed": true,
      "doneValues": [
        "done"
      ],
      "example": {
        "id": 1,
        "title": "实现 HTML 骨架",
        "description": "包含 DOCTYPE / head meta / body / Hello World 文本",
        "status": "pending",
        "output": "hello-world.html",
        "dependencies": []
      }
    }
  }
}